###
# 파일명: [.env|.env.example]
# 목적: 프로젝트 및 로그 설정
# 기능: 
#  - 설치 시 make env 명령으로 .env.example에서 .env 자동 생성
#  - 운영체제 인식
###

PROJECT_NAME=py-template

PROJECT_ROOT=
# PROJECT_ROOT=/path/to/your/project   # Linux/macOS
# PROJECT_ROOT=C:\path\to\your\project # Windows

LOG_PATH=$HOME/logs/{PROJECT_NAME}
# LOG_PATH=/var/log/{PROJECT_NAME}                             # Linux (prod 등, 인프라에서 디렉터리·권한 사전 준비 필요)
# LOG_PATH=$HOME/Library/Logs/{PROJECT_NAME}                   # macOS
# LOG_PATH=%USERPROFILE%\AppData\Local\{PROJECT_NAME}\logs     # Windows

LOG_LEVEL=DEBUG   # DEBUG, INFO, WARNING, ERROR, CRITICAL
